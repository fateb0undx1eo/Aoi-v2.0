# Discord Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_ID=your_bot_id_here
BOT_OWNER_ID=your_owner_id_here
BOT_ADMINS=admin_user_id_1,admin_user_id_2
DEV_SERVER_IDS=dev_server_id_1,dev_server_id_2
DEFAULT_PREFIX=!

# Reddit API (for meme commands)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=discord:yourbot:1.0 (by /u/yourusername)

# Some Random API Token (for image commands)
SRA_TOKEN=your_sra_token_here

# MongoDB Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Bot-specific IDs (optional)
ECLIPSE_ID=
ACCUSED_ROLE=
DOMAIN_EXPANSION=

# Logging Channels
GUILD_JOIN_LOGS_CHANNEL_ID=
GUILD_LEAVE_LOGS_CHANNEL_ID=
COMMAND_LOGS_CHANNEL_ID=
ERROR_WEBHOOK_URL=

# Dashboard Authentication
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password
SESSION_SECRET=generate_a_random_secret_key_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com
NODE_ENV=production

# DiscoBase Configuration
ERROR_LOGGING_ENABLED=true
PRESENCE_ENABLED=true
PRESENCE_STATUS=online
PRESENCE_INTERVAL=10000
PRESENCE_TYPE=PLAYING
PRESENCE_NAMES=with commands|with your server|DiscoBase v2.0.10
PRESENCE_STREAMING_URL=https://www.twitch.tv/example
PRESENCE_CUSTOM_STATE=🚀 discobase!
COMMAND_STATS_ENABLED=true
COMMAND_STATS_TRACK_USAGE=true
COMMAND_STATS_TRACK_SERVERS=true
COMMAND_STATS_TRACK_USERS=true
ACTIVITY_TRACKER_ENABLED=true
ACTIVITY_TRACKER_IGNORED_PATHS=**/node_modules/**,.git,.gitignore,discobase.json

